rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function congregationSignedIn() {
      return signedIn()
        && request.auth.token.role == "congregation"
        && request.auth.token.congregation_id is string;
    }

    function congregationMatches(congregationId) {
      return congregationSignedIn()
        && request.auth.token.congregation_id == congregationId;
    }

    match /congregations/{congregationId} {
      allow read: if congregationMatches(congregationId);
      allow write: if false;
    }

    match /activities/{activityId} {
      allow read: if congregationMatches(resource.data.congregation_id);
      allow write: if false;
    }

    match /agendas/{agendaId} {
      allow read, write: if congregationMatches(resource.data.congregation_id);
    }

    match /speakers/{speakerId} {
      allow read, write: if false;
    }
  }
}
